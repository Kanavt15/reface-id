{
  "name": "reface-forensic-reconstruction",
  "version": "1.0.0",
  "description": "Forensic Facial Reconstruction Desktop Application for Law Enforcement",
  "main": "src/electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:electron\"",
    "start:electron": "wait-on http://localhost:3001 && electron .",
    "start:backend": "node src/backend/server.js",
    "start:dev": "concurrently \"npm run dev:frontend\" \"npm run start:backend\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:frontend": "webpack serve --mode development --config webpack.config.js",
    "build": "webpack --mode production --config webpack.config.js",
    "build:electron": "electron-builder",
    "test": "jest",
    "lint": "eslint src/**/*.js src/**/*.jsx"
  },
  "keywords": [
    "forensic",
    "facial-reconstruction",
    "3d-modeling",
    "law-enforcement",
    "electron",
    "threejs"
  ],
  "author": "Forensic Tech Solutions",
  "license": "PROPRIETARY",
  "dependencies": {
    "@react-three/drei": "^9.88.0",
    "@react-three/fiber": "^8.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "three": "^0.159.0",
    "uuid": "^9.0.1",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.8.1",
    "electron": "^27.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.54.0",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "build": {
    "appId": "com.forensic.reface",
    "productName": "REface Forensic Reconstruction",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icons/icon.png"
    }
  }
}
